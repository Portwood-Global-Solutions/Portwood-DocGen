<apex:page controller="DocGenLandingController" showHeader="false" standardStylesheets="false" sidebar="false" applyHtmlTag="true" applyBodyTag="false" docType="html-5.0" cache="true">
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Community — Portwood DocGen</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #e2e8f0; background: #0f172a; line-height: 1.6; }
        a { color: #60a5fa; text-decoration: none; } a:hover { text-decoration: underline; }

        /* Header */
        .header { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; }
        .logo { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.5px; color: #fff; text-decoration: none; } .logo span { color: #60a5fa; }
        .header-links a { color: #94a3b8; margin-left: 1.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; } .header-links a:hover { color: #fff; }

        /* Hero */
        .hero { background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); text-align: center; padding: 4rem 2rem 3rem; }
        .hero h1 { font-size: 2.75rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 1rem; line-height: 1.1; color: #fff; }
        .hero h1 em { font-style: normal; color: #60a5fa; }
        .hero p { font-size: 1.15rem; color: #94a3b8; max-width: 680px; margin: 0 auto; }

        /* Section */
        .section { max-width: 960px; margin: 0 auto; padding: 4rem 2rem; }
        .section h2 { font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem; color: #fff; }
        .section .subtitle { text-align: center; color: #64748b; margin-bottom: 3rem; font-size: 1.05rem; }

        /* Steps */
        .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 3rem; }
        .step { text-align: center; }
        .step-num { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; font-size: 1.25rem; font-weight: 800; margin-bottom: 1rem; }
        .step h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 0.35rem; }
        .step p { color: #94a3b8; font-size: 0.9rem; }

        /* Group cards */
        .group-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
        .group-card { background: #1e293b; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.5rem; transition: border-color 0.2s; }
        .group-card:hover { border-color: rgba(255,255,255,0.12); }
        .group-icon { font-size: 1.75rem; margin-bottom: 0.75rem; display: block; }
        .group-card h3 { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 0.35rem; }
        .group-card p { color: #94a3b8; font-size: 0.88rem; }
        .gc-features { border-left: 3px solid #a855f7; }
        .gc-qa { border-left: 3px solid #fbbf24; }
        .gc-bugs { border-left: 3px solid #f87171; }
        .gc-show { border-left: 3px solid #4ade80; }
        .gc-templates { border-left: 3px solid #06b6d4; }
        .gc-general { border-left: 3px solid #60a5fa; }

        /* Join form */
        .join-section { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-top: 1px solid rgba(255,255,255,0.06); padding: 4rem 2rem; }
        .join-card { max-width: 480px; margin: 0 auto; background: #1e293b; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2.5rem; }
        .join-card h2 { font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 0.5rem; text-align: center; }
        .join-card .sub { text-align: center; color: #64748b; font-size: 0.9rem; margin-bottom: 2rem; }
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 600; color: #94a3b8; margin-bottom: 0.35rem; }
        .form-input { width: 100%; padding: 10px 14px; background: #0f172a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; font-size: 0.95rem; font-family: inherit; color: #e2e8f0; }
        .form-input:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
        .btn { display: inline-block; padding: 14px 32px; border-radius: 50px; font-size: 1rem; font-weight: 700; text-decoration: none; cursor: pointer; border: none; transition: transform 0.2s; }
        .btn:hover { transform: translateY(-2px); text-decoration: none; }
        .btn-primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,0.3); }
        .btn-full { width: 100%; text-align: center; }
        .form-note { text-align: center; color: #475569; font-size: 0.75rem; margin-top: 1rem; }
        .form-success { text-align: center; color: #4ade80; font-weight: 600; font-size: 1.1rem; display: none; }
        .form-error { text-align: center; color: #f87171; font-size: 0.85rem; margin-top: 0.75rem; display: none; }

        /* Existing member */
        .member-section { text-align: center; max-width: 960px; margin: 0 auto; padding: 0 2rem 3rem; }
        .member-section p { color: #64748b; font-size: 0.95rem; margin-bottom: 1rem; }
        .login-link { display: inline-block; padding: 12px 28px; border-radius: 50px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #60a5fa; font-weight: 700; font-size: 0.95rem; transition: background 0.2s; }
        .login-link:hover { background: rgba(255,255,255,0.1); text-decoration: none; }

        /* Why Chatter */
        .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
        .why-card { background: #1e293b; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.25rem; text-align: center; }
        .why-card h4 { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 0.25rem; }
        .why-card p { color: #64748b; font-size: 0.8rem; }
        .why-icon { font-size: 1.5rem; margin-bottom: 0.5rem; display: block; }

        /* Footer */
        .footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; text-align: center; color: #475569; font-size: 0.8rem; }
        .footer a { color: #60a5fa; }
        .footer-links { margin-bottom: 0.75rem; }
        .footer-links a { margin: 0 0.75rem; }

        @media (max-width: 700px) {
            .hero h1 { font-size: 2rem; }
            .steps { grid-template-columns: 1fr; gap: 1.5rem; }
            .header { flex-direction: column; gap: 0.5rem; }
            .header-links a { margin-left: 0.75rem; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="/DocGenLanding" class="logo">Portwood <span>DocGen</span></a>
        <nav class="header-links">
            <a href="/DocGenLanding">Home</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
        </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
        <h1>DocGen <em>Community</em></h1>
        <p>A free community powered by Salesforce Chatter. Ask questions, request features, share templates, and help shape the roadmap — all inside the platform you already know.</p>
    </section>

    <!-- How It Works -->
    <section class="section">
        <h2>How It Works</h2>
        <p class="subtitle">Three steps to join the conversation</p>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <h3>Sign Up</h3>
                <p>Enter your name and email below. Your free Chatter account is created instantly — no Salesforce license required.</p>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <h3>Check Your Email</h3>
                <p>Salesforce sends you a welcome email with your login link. Set your password and you're in.</p>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <h3>Join the Conversation</h3>
                <p>You're automatically added to all DocGen community groups. Post, comment, share files, and @mention others.</p>
            </div>
        </div>
    </section>

    <!-- Chatter Groups -->
    <section class="section" style="padding-top: 0;">
        <h2>Community Groups</h2>
        <p class="subtitle">Organized conversations so you can find what you need</p>
        <div class="group-grid">
            <div class="group-card gc-features">
                <span class="group-icon">&#x1F4A1;</span>
                <h3>Feature Requests</h3>
                <p>Suggest new features and vote on what gets built next. The most-requested features drive the roadmap.</p>
            </div>
            <div class="group-card gc-qa">
                <span class="group-icon">&#x2753;</span>
                <h3>Questions &amp; Answers</h3>
                <p>Get help with templates, merge tags, query configs, Flows, and anything else DocGen-related.</p>
            </div>
            <div class="group-card gc-bugs">
                <span class="group-icon">&#x1F41B;</span>
                <h3>Bug Reports</h3>
                <p>Found something broken? Report it here. We triage and fix bugs fast.</p>
            </div>
            <div class="group-card gc-show">
                <span class="group-icon">&#x1F31F;</span>
                <h3>Show &amp; Tell</h3>
                <p>Share what you've built with DocGen — invoices, contracts, reports, creative use cases.</p>
            </div>
            <div class="group-card gc-templates">
                <span class="group-icon">&#x1F4C4;</span>
                <h3>Template Sharing</h3>
                <p>Share and download ready-to-use Word templates. Help others get started faster.</p>
            </div>
            <div class="group-card gc-general">
                <span class="group-icon">&#x1F4AC;</span>
                <h3>General Discussion</h3>
                <p>Everything else — announcements, tips and tricks, Salesforce news, community chat.</p>
            </div>
        </div>
    </section>

    <!-- Why Chatter -->
    <section class="section" style="padding-top: 0;">
        <h2>Why Chatter?</h2>
        <p class="subtitle">We built DocGen for Salesforce admins — the community should live where you already work</p>
        <div class="why-grid">
            <div class="why-card">
                <span class="why-icon">&#x1F4B0;</span>
                <h4>100% Free</h4>
                <p>Chatter Free licenses cost nothing. No subscriptions, no forum hosting fees.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F50D;</span>
                <h4>Searchable</h4>
                <p>Find answers with Chatter's built-in search. No more digging through threads.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F514;</span>
                <h4>Notifications</h4>
                <p>Get notified when someone replies, @mentions you, or posts in your groups.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F4CE;</span>
                <h4>File Sharing</h4>
                <p>Share templates, screenshots, and documents directly in posts. Native file support.</p>
            </div>
        </div>
    </section>

    <!-- Join Form -->
    <section class="join-section">
        <div class="join-card" id="joinForm">
            <h2>Join the Community</h2>
            <p class="sub">Instant signup. Your Chatter account is created immediately.</p>
            <div class="form-group">
                <label for="joinName">Name</label>
                <input type="text" id="joinName" class="form-input" placeholder="Jane Smith" />
            </div>
            <div class="form-group">
                <label for="joinEmail">Email</label>
                <input type="email" id="joinEmail" class="form-input" placeholder="jane@company.com" />
            </div>
            <div class="form-group">
                <label for="joinCompany">Company</label>
                <input type="text" id="joinCompany" class="form-input" placeholder="Acme Corp" />
            </div>
            <button type="button" class="btn btn-primary btn-full" id="joinBtn" onclick="submitJoin()">Request Access</button>
            <div class="form-error" id="joinError"></div>
            <p class="form-note">No Salesforce license required. Chatter Free accounts are 100% free.</p>
        </div>
        <div class="form-success" id="joinSuccess" style="padding: 2rem;">
            You're in! Check your email for a welcome message from Salesforce with your login link.
        </div>

        <!-- Existing members -->
        <div class="member-section" style="margin-top: 2.5rem;">
            <p>Already have an account?</p>
            <a href="https://portwoodglobalsolutions.my.salesforce.com" class="login-link" target="_blank">Log In to Chatter</a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-links">
            <a href="/DocGenLanding">Home</a>
            <a href="/DocGenCommunity">Community</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
            <a href="/DocGenTerms">Terms</a>
            <a href="/DocGenPrivacy">Privacy</a>
        </div>
        <p>Built by <a href="https://portwoodglobalsolutions.com">Portwood Global Solutions</a></p>
    </footer>

    <script>
        function submitJoin() {
            var name = document.getElementById('joinName').value.trim();
            var email = document.getElementById('joinEmail').value.trim();
            var company = document.getElementById('joinCompany').value.trim();
            var errEl = document.getElementById('joinError');
            var btn = document.getElementById('joinBtn');

            errEl.style.display = 'none';

            if (!name || !email) {
                errEl.textContent = 'Please enter your name and email.';
                errEl.style.display = 'block';
                return;
            }
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                errEl.textContent = 'Please enter a valid email address.';
                errEl.style.display = 'block';
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Submitting...';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenLandingController.createChatterUser}',
                name, email, company,
                function(result, event) {
                    if (event.status) {
                        document.getElementById('joinForm').style.display = 'none';
                        var msg = document.getElementById('joinSuccess');
                        if (result === 'reactivated') {
                            msg.textContent = 'Welcome back! Your account has been reactivated. Log in at portwoodglobalsolutions.my.salesforce.com.';
                        }
                        msg.style.display = 'block';
                    } else {
                        errEl.textContent = event.message || 'Something went wrong. Please try again.';
                        errEl.style.display = 'block';
                        btn.disabled = false;
                        btn.textContent = 'Request Access';
                    }
                },
                { escape: true }
            );
        }
    </script>

</body>
</html>
</apex:page>
