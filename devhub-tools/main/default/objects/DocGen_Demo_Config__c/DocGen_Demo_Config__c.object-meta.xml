<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Stores demo org OAuth credentials and session for the DocGen landing page. Partner org only.</description>
    <enableFeeds>false</enableFeeds>
    <label>DocGen Demo Config</label>
    <visibility>Public</visibility>
    <fields>
        <fullName>Client_Id__c</fullName>
        <description>Connected App Consumer Key from demo org</description>
        <externalId>false</externalId>
        <label>Client Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Client_Secret__c</fullName>
        <description>Connected App Consumer Secret from demo org</description>
        <externalId>false</externalId>
        <label>Client Secret</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Instance_Url__c</fullName>
        <description>Demo org instance URL</description>
        <externalId>false</externalId>
        <label>Instance Url</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Access_Token__c</fullName>
        <description>Current OAuth access token from demo org</description>
        <externalId>false</externalId>
        <label>Access Token</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Last_Refreshed__c</fullName>
        <description>When the session was last refreshed</description>
        <externalId>false</externalId>
        <label>Last Refreshed</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
</CustomObject>
