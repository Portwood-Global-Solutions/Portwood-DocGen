<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Page_Orientation__c</fullName>
    <description>PDF page orientation snapshot for this version. Landscape routes through the Visualforce PDF page; Portrait uses Blob.toPdf directly.</description>
    <label>Page Orientation</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Portrait</fullName>
                <default>true</default>
                <label>Portrait</label>
            </value>
            <value>
                <fullName>Landscape</fullName>
                <default>false</default>
                <label>Landscape</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
